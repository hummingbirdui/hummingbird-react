rs"},"871":{"id":"/docs/layout/grid-19","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row-columns-gutters","content":"Row columns gutters"},"872":{"id":"/docs/layout/grid-20","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#no-gutters","content":"No gutters"},"873":{"id":"/docs/layout/grid-21","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#api-reference","content":"API Reference"},"874":{"id":"/docs/layout/grid-22","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row","content":"Row"},"875":{"id":"/docs/layout/grid-23","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#col","content":"Col"},"876":{"id":"/docs/layout/grid-24","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#css-variables","content":"CSS variables"},"877":{"id":"/docs/layout/grid-25","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#styling","content":"Styling"},"878":{"id":"/docs/layout/grid-26","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#basic-example","content":"The Grid uses the `Container`, `Row`, and `Col` components to create responsive layouts. It is built with flexbox and adapts to different screen sizes."},"879":{"id":"/docs/layout/grid-27","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#auto-layout-columns","content":"Breakpoint props allow easy sizing of columns without setting an explicit numbered span."},"880":{"id":"/docs/layout/grid-28","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#equal-width","content":"A `Col` without any props creates equal-width columns for every screen size."},"881":{"id":"/docs/layout/grid-29","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#variable-width-content","content":"Setting a breakpoint prop to `\"auto\"` sizes the column based on the natural width of its content."},"882":{"id":"/docs/layout/grid-30","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#responsive-props","content":"The `xs`, `sm`, `md`, `lg`, `xl`, and `xxl` props specify different column sizes for different screen sizes. Breakpoints are defined using minimum widths, meaning each one applies from that width upward. For example, `md={4}` applies to medium devices (tablets) and above, and renders the `md:col-4` class."},"883":{"id":"/docs/layout/grid-31","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#all-breakpoints","content":"For grids that are the same across all breakpoints, plain `Col` and the `xs` prop are enough."},"884":{"id":"/docs/layout/grid-32","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#mix-and-match","content":"Different breakpoint props can be combined on the same column for different screen sizes."},"885":{"id":"/docs/layout/grid-33","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns","content":"Instead of sizing each column, the `Row` breakpoint props set the number of columns per row. The grid automatically lays out the columns evenly, and `\"auto\"` sizes them based on their content."},"886":{"id":"/docs/layout/grid-34","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#nesting","content":"Nesting works by placing a new `Row` and set of `Col` components inside an existing `Col`. This gives more control over the layout of the content."},"887":{"id":"/docs/layout/grid-35","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#columns","content":"Columns can be modified with options for alignment, ordering, and offsetting using the flexbox grid system."},"888":{"id":"/docs/layout/grid-36","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `items-start`, `items-center`, and `items-end` classes on `Row` control vertical alignment of all columns."},"889":{"id":"/docs/layout/grid-37","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `self-start`, `self-center`, and `self-end` classes control vertical alignment of individual columns."},"890":{"id":"/docs/layout/grid-38","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-alignment","content":"The `justify-*` classes on `Row` control horizontal alignment."},"891":{"id":"/docs/layout/grid-39","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#order-classes","content":"The `order-{number}` classes change the visual order of columns."},"892":{"id":"/docs/layout/grid-40","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#offsetting-columns","content":"The object form of a breakpoint prop moves columns to the right. For example, `md={{ span: 4, offset: 4 }}` renders the `md:col-4 md:offset-4` classes, moving the column over four columns on medium screens and larger."},"893":{"id":"/docs/layout/grid-41","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#gutters","content":"Gutters are the spacing between columns, used to create consistent spacing and alignment in the grid system. Hummingbird supports gutter utilities up to `g-24` (6rem), applied to `Row` through the `className` prop."},"894":{"id":"/docs/layout/grid-42","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-gutters","content":"The `gx-{size}` classes set horizontal gutters between columns."},"895":{"id":"/docs/layout/grid-43","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-gutters","content":"The `gy-{size}` classes set vertical gutters between rows."},"896":{"id":"/docs/layout/grid-44","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal--vertical-gutters","content":"The `g-{size}` classes set both horizontal and vertical gutters."},"897":{"id":"/docs/layout/grid-45","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns-gutters","content":"Gutter classes can be combined with the `Row` breakpoint props to create gutters between rows and columns."},"898":{"id":"/docs/layout/grid-46","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#no-gutters","content":"The `g-0` class removes all gutters between rows and columns."},"899":{"id":"/docs/layout/grid-47","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#api-reference","content":"The grid components are available from `@hummingbirdui/react` or the `@hummingbirdui/react/layout/grid` subpath. All three render a `<div>` and accept standard div attributes."},"900":{"id":"/docs/layout/grid-48","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#css-variables","content":"The Grid uses CSS variables for easy customization. Override these variables in the CSS to change the grid's behavior."},"901":{"id":"/docs/layout/grid-49","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#styling","content":"Hummingbird React grid components are styled entirely through Hummingbird's grid classes and CSS variables. See the Hummingbird Grid documentation for the full class reference."},"902":{"id":"/docs/getting-started/installation","page_id":"/docs/getting-started/installation","type":"page","content":"Installation","breadcrumbs":["Docs","Getting Started"],"tags":[],"url":"/docs/getting-started/installation"},"903":{"id":"/docs/getting-started/installation-0","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation","content":"Install Hummingbird React and set it up in your project."},"904":{"id":"/docs/getting-started/installation-1","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#installation","content":"Installation"},"905":{"id":"/docs/getting-started/installation-2","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#1-install-tailwind-css","content":"1\\. Install Tailwind CSS"},"906":{"id":"/docs/getting-started/installation-3","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#2-install-hummingbird-react","content":"2\\. Install Hummingbird React"},"907":{"id":"/docs/getting-started/installation-4","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#3-import-css","content":"3\\. Import CSS"},"908":{"id":"/docs/getting-started/installation-5","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#4-use-components","content":"4\\. Use components"},"909":{"id":"/docs/getting-started/installation-6","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#typescript-support","content":"TypeScript support"},"910":{"id":"/docs/getting-started/installation-7","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#customization","content":"Customization"},"911":{"id":"/docs/getting-started/installation-8","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#1-install-tailwind-css","content":"Ensure the project is set up with Tailwind CSS. If Tailwind CSS hasn't been set up yet, follow the official installation guide."},"912":{"id":"/docs/getting-started/installation-9","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#2-install-hummingbird-react","content":"Install Hummingbird React via a preferred package manager. The `@hummingbirdui/hummingbird` package provides the styles and is required as a peer dependency."},"913":{"id":"/docs/getting-started/installation-10","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"Import Hummingbird styles in the main CSS file (e.g., `globals.css`), and register the package as a source so the Tailwind compiler scans it for class names."},"914":{"id":"/docs/getting-started/installation-11","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"The `@source` directive is required because Tailwind does not scan node\\_modules by default. Since Hummingbird generates component classes on demand, Tailwind must scan the `@hummingbirdui/react` package. Update the relative path so it points to node\\_modules from your CSS file."},"915":{"id":"/docs/getting-started/installation-12","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"No per-component CSS imports or manual purge configuration are needed."},"916":{"id":"/docs/getting-started/installation-13","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#4-use-components","content":"Import any component and use it in the application."},"917":{"id":"/docs/getting-started/installation-14","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#typescript-support","content":"Hummingbird React is written in TypeScript and includes type definitions for all components. Component props are fully typed and available on each component's namespace, so no additional `@types` packages are needed."},"918":{"id":"/docs/getting-started/installation-15","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"All components accept a `className` prop. Custom classes are merged with the component classes, so Tailwind utility classes can be used to adjust any component."},"919":{"id":"/docs/getting-started/installation-16","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"For theme-level changes such as colors and spacing, Hummingbird provides global and component-specific CSS variables. See the Customize section for details."},"920":{"id":"/docs/getting-started/introduction","page_id":"/docs/getting-started/introduction","type":"page","content":"Introduction","breadcrumbs":["Docs","Getting Started"],"tags":[],"url":"/docs/getting-started/introduction"},"921":{"id":"/docs/getting-started/introduction-0","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction","content":"Welcome to the Hummingbird React documentation. It is an open-source React component library built on Hummingbird CSS and Radix UI primitives."},"922":{"id":"/docs/getting-started/introduction-1","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"What is Hummingbird React?"},"923":{"id":"/docs/getting-started/introduction-2","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Why Hummingbird React?"},"924":{"id":"/docs/getting-started/introduction-3","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"Pre-requisite knowledge"},"925":{"id":"/docs/getting-started/introduction-4","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#join-our-community","content":"Join our community"},"926":{"id":"/docs/getting-started/introduction-5","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"Hummingbird React is the official React component library for the Hummingbird design system. It provides a large set of accessible, fully styled React components such as buttons, forms, dialogs, and dropdowns, along with patterns suitable for dashboards, SaaS applications, and e-commerce systems."},"927":{"id":"/docs/getting-started/introduction-6","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"The library follows one core principle: **Hummingbird CSS owns the visuals, and Radix UI owns the behavior**. Every component is styled with Hummingbird's component classes on top of Tailwind CSS, while interactive components use Radix UI primitives for keyboard navigation, focus management, and accessibility. Hummingbird React is the bridge between the two."},"928":{"id":"/docs/getting-started/introduction-7","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides ready-to-use React components with a consistent, typed API."},"929":{"id":"/docs/getting-started/introduction-8","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Ships accessible behavior out of the box through Radix UI primitives."},"930":{"id":"/docs/getting-started/introduction-9","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Reduces reliance on large sets of Tailwind utility classes."},"931":{"id":"/docs/getting-started/introduction-10","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Offers component variants through simple props such as `variant`, `color`, and `size`."},"932":{"id":"/docs/getting-started/introduction-11","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports full customization using the `className` prop and Tailwind utility classes."},"933":{"id":"/docs/getting-started/introduction-12","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides global and component-specific CSS variables for deeper configuration."},"934":{"id":"/docs/getting-started/introduction-13","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Includes complete TypeScript definitions for every component."},"935":{"id":"/docs/getting-started/introduction-14","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports tree shaking through per-component imports."},"936":{"id":"/docs/getting-started/introduction-15","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"HTML"},"937":{"id":"/docs/getting-started/introduction-16","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"CSS"},"938":{"id":"/docs/getting-started/introduction-17","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"JavaScript"},"939":{"id":"/docs/getting-started/introduct