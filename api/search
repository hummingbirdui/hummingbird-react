#key-idea","content":"`--border-color-default`"},"581":{"id":"/docs/customize/dark-mode-20","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#result","content":"Switching themes requires no component changes — only variable values update. Every Hummingbird React component adapts automatically."},"582":{"id":"/docs/customize/dark-mode-21","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Override variables after importing Hummingbird:"},"583":{"id":"/docs/customize/dark-mode-22","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"Enable class-based dark mode after importing Tailwind and Hummingbird styles:"},"584":{"id":"/docs/customize/dark-mode-23","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"Render `ThemeModeScript` inside `<head>` to apply the saved theme before first paint — no flash of the wrong theme. Safe in React Server Components."},"585":{"id":"/docs/customize/dark-mode-24","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"`DarkThemeToggle` switches between light and dark mode, persists the choice, and keeps all tabs in sync."},"586":{"id":"/docs/customize/dark-mode-25","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"Pass your own icons to replace the default sun/moon:"},"587":{"id":"/docs/customize/dark-mode-26","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"It is built on Button, so all `Button` props work too."},"588":{"id":"/docs/customize/dark-mode-27","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#the-usethememode-hook","content":"For custom controls, use `useThemeMode`. It applies the `.dark` class, follows the OS preference in `\"system\"` mode, and stays in sync across components and browser tabs. `DarkThemeToggle` uses it internally."},"589":{"id":"/docs/customize/dark-mode-28","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"A list of theme variables that are overridden when dark mode is active."},"590":{"id":"/docs/customize/reboot","page_id":"/docs/customize/reboot","type":"page","content":"Reboot","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/reboot"},"591":{"id":"/docs/customize/reboot-0","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot","content":"Reboot is a file that includes a set of CSS with element-specific changes that gives Hummingbird a clean, consistent starting point for building websites."},"592":{"id":"/docs/customize/reboot-1","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#css-variables","content":"CSS variables"},"593":{"id":"/docs/customize/reboot-2","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#headings","content":"Headings"},"594":{"id":"/docs/customize/reboot-3","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#paragraph","content":"Paragraph"},"595":{"id":"/docs/customize/reboot-4","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#links","content":"Links"},"596":{"id":"/docs/customize/reboot-5","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#buttons","content":"Buttons"},"597":{"id":"/docs/customize/reboot-6","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#horizontal-rules","content":"Horizontal rules"},"598":{"id":"/docs/customize/reboot-7","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#lists","content":"Lists"},"599":{"id":"/docs/customize/reboot-8","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#description-lists","content":"Description lists"},"600":{"id":"/docs/customize/reboot-9","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#code","content":"Code"},"601":{"id":"/docs/customize/reboot-10","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#address","content":"Address"},"602":{"id":"/docs/customize/reboot-11","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#blockquote","content":"Blockquote"},"603":{"id":"/docs/customize/reboot-12","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#legend","content":"Legend"},"604":{"id":"/docs/customize/reboot-13","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#captions","content":"Captions"},"605":{"id":"/docs/customize/reboot-14","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#reboot-css-variables","content":"Reboot CSS variables"},"606":{"id":"/docs/customize/reboot-15","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"CSS variables provide a powerful way to customize and theme projects. It is a feature in modern CSS that allows defining reusable values directly in stylesheets. CSS variables make customization easy: change a value in one place (like `:root`) and it updates everywhere the variable is used. Variables can be set at different levels (global, component, etc.), making them flexible."},"607":{"id":"/docs/customize/reboot-16","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"A \"Reboot\" stylesheet (like Hummingbird's Reboot) resets browser styles and sets up a foundation for consistent design. Using CSS variables in Reboot makes it easy to customize base styles without editing the core CSS — just override the variables."},"608":{"id":"/docs/customize/reboot-17","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Tailwind CSS uses CSS variables for theming and customization. Hummingbird makes use of Tailwind's CSS variable feature to define colors, typography, spacing, and more. This allows projects to easily adapt the design system to specific needs. Learn more about Hummingbird's CSS variables in the Theming section."},"609":{"id":"/docs/customize/reboot-18","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Reboot is included automatically when Hummingbird CSS is imported, so JSX elements rendered by React components get these base styles with no extra setup."},"610":{"id":"/docs/customize/reboot-19","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#headings","content":"All the headings (`h1` to `h6`) in Hummingbird are styled with CSS variables for font size, weight, line height, and margin."},"611":{"id":"/docs/customize/reboot-20","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#paragraph","content":"For all paragraph (`<p>`) elements, `margin-top` was removed, and `margin-bottom: 1rem` is set."},"612":{"id":"/docs/customize/reboot-21","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#links","content":"Links are styled with a default `color` and an `underline`. On hover, the link color changes to a darker shade."},"613":{"id":"/docs/customize/reboot-22","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#buttons","content":"By default, buttons (`<button>`) have a `cursor-pointer` style. When a button is disabled, the cursor changes to `cursor-default`."},"614":{"id":"/docs/customize/reboot-23","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#horizontal-rules","content":"Default `margin-top` and `margin-bottom` for horizontal rules (`<hr>`) is set to `1rem`."},"615":{"id":"/docs/customize/reboot-24","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#lists","content":"By default, unordered lists (`<ul>`) use disc bullets, and ordered lists (`<ol>`) use decimal numbers. Both types of lists have a left padding of `2rem` and a bottom margin of `1rem`. Nested lists have no bottom margin."},"616":{"id":"/docs/customize/reboot-25","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#description-lists","content":"Terms (`<dt>`) are styled with a bold font weight, while descriptions (`<dd>`) use a regular font weight. Default `margin-bottom` for `<dl>` is `1rem`."},"617":{"id":"/docs/customize/reboot-26","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#code","content":"By default, inline code elements (`<code>`) are styled with a specific text color and font size. When a `<code>` element is nested inside an `<a>` tag, it inherits the link's text color and font size."},"618":{"id":"/docs/customize/reboot-27","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#address","content":"The `<address>` element is styled with a bottom margin of `1rem`."},"619":{"id":"/docs/customize/reboot-28","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#blockquote","content":"By default, blockquotes (`<blockquote>`) have a bottom margin of `1rem`."},"620":{"id":"/docs/customize/reboot-29","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#legend","content":"The `<legend>` element is styled to be a block-level element with full width, no padding, and specific margin, font weight, and font size."},"621":{"id":"/docs/customize/reboot-30","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#captions","content":"By default, table captions (`<caption>`) are aligned to the left and positioned at the bottom of the table. They also have specific font weight and padding."},"622":{"id":"/docs/customize/reboot-31","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#reboot-css-variables","content":"The following CSS variables are defined in Hummingbird for reboot styles. Override these variables in the CSS to customize the base styles of the project."},"623":{"id":"/docs/customize/theming","page_id":"/docs/customize/theming","type":"page","content":"Theming","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/theming"},"624":{"id":"/docs/customize/theming-0","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming","content":"Learn how to customize Hummingbird React with Tailwind CSS v4 theme variables, override tokens, and support multiple themes and dark mode."},"625":{"id":"/docs/customize/theming-1","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#overview","content":"Overview"},"626":{"id":"/docs/customize/theming-2","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#available-themes","content":"Available themes"},"627":{"id":"/docs/customize/theming-3","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-themes","content":"How to use themes"},"628":{"id":"/docs/customize/theming-4","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#customizing-theme","content":"Customizing theme"},"629":{"id":"/docs/customize/theming-5","page_i