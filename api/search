ng-started/installation-4","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#3-import-css","content":"3\\. Import CSS"},"563":{"id":"/docs/getting-started/installation-5","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#4-use-components","content":"4\\. Use components"},"564":{"id":"/docs/getting-started/installation-6","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#typescript-support","content":"TypeScript support"},"565":{"id":"/docs/getting-started/installation-7","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#customization","content":"Customization"},"566":{"id":"/docs/getting-started/installation-8","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#1-install-tailwind-css","content":"Ensure the project is set up with Tailwind CSS. If Tailwind CSS hasn't been set up yet, follow the official installation guide."},"567":{"id":"/docs/getting-started/installation-9","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#2-install-hummingbird-react","content":"Install Hummingbird React via a preferred package manager. The `@hummingbirdui/hummingbird` package provides the styles and is required as a peer dependency."},"568":{"id":"/docs/getting-started/installation-10","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"Import Hummingbird styles in the main CSS file (e.g., `globals.css`), and register the package as a source so the Tailwind compiler scans it for class names."},"569":{"id":"/docs/getting-started/installation-11","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"The `@source` directive is required because Tailwind does not scan node\\_modules by default. Since Hummingbird generates component classes on demand, Tailwind must scan the `@hummingbirdui/react` package. Update the relative path so it points to node\\_modules from your CSS file."},"570":{"id":"/docs/getting-started/installation-12","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"No per-component CSS imports or manual purge configuration are needed."},"571":{"id":"/docs/getting-started/installation-13","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#4-use-components","content":"Import any component and use it in the application."},"572":{"id":"/docs/getting-started/installation-14","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#typescript-support","content":"Hummingbird React is written in TypeScript and includes type definitions for all components. Component props are fully typed, so no additional `@types` packages are needed."},"573":{"id":"/docs/getting-started/installation-15","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"All components accept a `className` prop. Custom classes are merged with the component classes, so Tailwind utility classes can be used to adjust any component."},"574":{"id":"/docs/getting-started/installation-16","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"For theme-level changes such as colors and spacing, Hummingbird provides global and component-specific CSS variables. See the Customize section for details."},"575":{"id":"/docs/getting-started/introduction","page_id":"/docs/getting-started/introduction","type":"page","content":"Introduction","breadcrumbs":["Docs","Getting Started"],"tags":[],"url":"/docs/getting-started/introduction"},"576":{"id":"/docs/getting-started/introduction-0","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction","content":"Welcome to the Hummingbird React documentation. It is an open-source React component library built on Hummingbird CSS and Radix UI primitives."},"577":{"id":"/docs/getting-started/introduction-1","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"What is Hummingbird React?"},"578":{"id":"/docs/getting-started/introduction-2","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Why Hummingbird React?"},"579":{"id":"/docs/getting-started/introduction-3","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"Pre-requisite knowledge"},"580":{"id":"/docs/getting-started/introduction-4","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#join-our-community","content":"Join our community"},"581":{"id":"/docs/getting-started/introduction-5","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"Hummingbird React is the official React component library for the Hummingbird design system. It provides a large set of accessible, fully styled React components such as buttons, forms, dialogs, and dropdowns, along with patterns suitable for dashboards, SaaS applications, and e-commerce systems."},"582":{"id":"/docs/getting-started/introduction-6","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"The library follows one core principle: **Hummingbird CSS owns the visuals, and Radix UI owns the behavior**. Every component is styled with Hummingbird's component classes on top of Tailwind CSS, while interactive components use Radix UI primitives for keyboard navigation, focus management, and accessibility. Hummingbird React is the bridge between the two."},"583":{"id":"/docs/getting-started/introduction-7","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides ready-to-use React components with a consistent, typed API."},"584":{"id":"/docs/getting-started/introduction-8","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Ships accessible behavior out of the box through Radix UI primitives."},"585":{"id":"/docs/getting-started/introduction-9","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Reduces reliance on large sets of Tailwind utility classes."},"586":{"id":"/docs/getting-started/introduction-10","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Offers component variants through simple props such as `variant`, `color`, and `size`."},"587":{"id":"/docs/getting-started/introduction-11","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports full customization using the `className` prop and Tailwind utility classes."},"588":{"id":"/docs/getting-started/introduction-12","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides global and component-specific CSS variables for deeper configuration."},"589":{"id":"/docs/getting-started/introduction-13","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Includes complete TypeScript definitions for every component."},"590":{"id":"/docs/getting-started/introduction-14","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports tree shaking through per-component imports."},"591":{"id":"/docs/getting-started/introduction-15","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"HTML"},"592":{"id":"/docs/getting-started/introduction-16","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"CSS"},"593":{"id":"/docs/getting-started/introduction-17","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"JavaScript"},"594":{"id":"/docs/getting-started/introduction-18","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"React"},"595":{"id":"/docs/getting-started/introduction-19","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"Tailwind CSS"},"596":{"id":"/docs/getting-started/introduction-20","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#join-our-community","content":"If you have any questions about Hummingbird React, you can reach out to our community on GitHub Discussions, Discord or X (Twitter)."},"597":{"id":"/docs/customize/colors","page_id":"/docs/customize/colors","type":"page","content":"Colors","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/colors"},"598":{"id":"/docs/customize/colors-0","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors","content":"Hummingbird provides a small set of semantic color variables, which makes it easy to apply and customize colors consistently across the project."},"599":{"id":"/docs/customize/colors-1","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#overview","content":"Overview"},"600":{"id":"/docs/customize/colors-2","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#background-colors","content":"Background colors"},"601":{"id":"/docs/customize/colors-3","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#text-colors","content":"Text colors"},"602":{"id":"/docs/customize/colors-4","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#border-colors","content":"Border colors"},"603":{"id":"/docs/customize/colors-5","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#action-colors","content":"Action colors"},"604":{"id":"/docs/customize/colors-6","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#theme-colors","content":"Theme colors"},"605":{"id":"/docs/customize/colors-7","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#how-to-use","content":"How to use"},"606":{"id":"/docs/customize/colors-8","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#customize-color","content":"Customize color"},"607":{"id":"/docs/customize/colors-9","page_id":"/docs/customize/colors","type":"heading","tags":[],"url":"/docs/customize/colors#color-palettes","content":"Color palettes"},"608":{"id":"/docs/customize/colors-10","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"Instead of applying fixed Tailwind palette classes like:"},"609":{"id":"/docs/customize/colors-11","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`text-red-500`"},"610":{"id":"/docs/customize/colors-12","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`bg-green-600`"},"611":{"id":"/docs/customize/colors-13","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`border-blue-700` etc."},"612":{"id":"/docs/customize/colors-14","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"It is recommended to rely on semantic color classes. Semantic colors are mapped to design tokens and automatically adapt when themes change."},"613":{"id":"/docs/customize/colors-15","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"For example,"},"614":{"id":"/docs/customize/colors-16","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`text-primary`"},"615":{"id":"/docs/customize/colors-17","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`bg-subtle`"},"616":{"id":"/docs/customize/colors-18","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`border-subtle` etc."},"617":{"id":"/docs/customize/colors-19","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"This approach prevents dependence on specific palette values (`blue-500`, `green-600`, etc.). Instead, components reference semantic roles (`primary`, `secondary`, `warning`), making the UI easier to maintain, brand, and theme."},"618":{"id":"/docs/customize/colors-20","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"Behind the scenes, each semantic color class points to a CSS variable. Updating or overriding that variable updates the color everywhere it is used — including inside every Hummingbird React component."},"619":{"id":"/docs/customize/colors-21","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#action-colors","content":"These colors generate all color-related utilities and are used by components for interactive states."},"620":{"id":"/docs/customize/colors-22","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#theme-colors","content":"Each semantic color comes in five steps: `lighter`, `light`, the base color, `dark`, and `darker`. Every step generates all color-related utilities (`bg-*`, `text-*`, `border-*`, and more) and is available as a CSS variable."},"621":{"id":"/docs/customize/colors-23","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"Use semantic color classes like:"},"622":{"id":"/docs/customize/colors-24","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`bg-primary`"},"623":{"id":"/docs/customize/colors-25","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`text-muted`"},"624":{"id":"/docs/customize/colors-26","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`border-default`"},"625":{"id":"/docs/customize/colors-27","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"These classes use the theme's color variables, so the UI stays consistent when customizing or switching themes. They can be applied to any element or passed to any component through the `className` prop."},"626":{"id":"/docs/customize/colors-28","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#customize-color","content":"Override any theme color or palette color by redefining its CSS variable inside a `@theme` block after importing Hummingbird:"},"627":{"id":"/docs/customize/colors-29","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#color-palettes","content":"Each Hummingbird theme includes its own complete color palette, carefully designed to maintain a consistent visual tone. Use these palettes to customize existing themes or create entirely new ones. See the default color palette reference in the Hummingbird documentation for the complete list of colors and their values."},"628":{"id":"/docs/customize/component","page_id":"/docs/customize/component","type":"page","content":"Component Customization","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/component"},"629":{"id":"/docs/customize/component-0","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component","content":"Hummingbird React components can be customized using props, utility classes, or CSS variables to match specific design needs."},"630":{"id":"/docs/customize/component-1","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-props","content":"Using props"},"631":{"id":"/docs/customize/component-2","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-tailwind-utility-classes","content":"Using Tailwind utility classes"},"632":{"id":"/docs/customize/component-3","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-the-apply-directive","content":"Using the `@apply` directive"},"633":{"id":"/docs/customize/component-4","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-css-variables","content":"Using CSS variables"},"634":{"id":"/docs/customize/component-5","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#option-1-global-variables","content":"Option 1: Global variables"},"635":{"id":"/docs/customize/component-6","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#option-2-local-variables","content":"Option 2: Local variables"},"636":{"id":"/docs/customize/component-7","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-props","content":"Every Hummingbird React component ships with variants that are controlled through props. This is the first and simplest level of customization. For example, the button component can be adjusted with the `variant`, `color`, `size`, and `shape` props."},"637":{"id":"/docs/customize/component-8","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-props","content":"The available props for each component are listed in the API Reference section of its documentation page."},"638":{"id":"/docs/customize/component-9","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-tailwind-utility-classes","content":"All components accept a `className` prop. Custom classes are merged with the component classes, so any Tailwind utility can be applied on top. For example, rounded pill buttons can be created by adding the `rounded-full` class."},"639":{"id":"/docs/customize/component-10","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-the-apply-directive","content":"Customization can also be done in a CSS file using Tailwind CSS's `@apply` directive. Because the components render Hummingbird's CSS classes (such as `btn`), overriding the class changes every instance of the component."},"640":{"id":"/docs/customize/component-11","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-css-variables","content":"Hummingbird components are styled with a set of CSS variables. These variables make it easy to customize styles either globally (across the entire project) or locally (for a specific component)."},"641":{"id":"/docs/customize/component-12","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-css-variables","content":"For example, to update or customize the Button component, override its CSS variables:"},"642":{"id":"/docs/customize/component-13","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-1-global-variables","content":"Override the theme variables globally under `@theme`. This will apply the changes across all components in the project."},"643":{"id":"/docs/customize/component-14","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"Override the component variables locally under the component's class or a custom class. This will apply the changes only to that specific component."},"644":{"id":"/docs/customize/component-15","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"To scope the change to only some buttons, pass a custom class through the `className` prop and target that class in CSS."},"645":{"id":"/docs/customize/dark-mode","page_id":"/docs/customize/dark-mode","type":"page","content":"Dark Mode","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/dark-mode"},"646":{"id":"/docs/customize/dark-mode-0","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode","content":"This guide explains how to enable and manage dark mode in a React application, in a way consistent with Tailwind's dark-mode documentation."},"647":{"id":"/docs/customize/dark-mode-1","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#how-it-works","content":"How it works"},"648":{"id":"/docs/customize/dark-mode-2","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#key-idea","content":"Key idea"},"649":{"id":"/docs/customize/dark-mode-3","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#result","content":"Result"},"650":{"id":"/docs/customize/dark-mode-4","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Customizing dark mode"},"651":{"id":"/docs/customize/dark-mode-5","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#setting-up-dark-mode","content":"Setting up dark mode"},"652":{"id":"/docs/customize/dark-mode-6","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"1\\. Custom dark mode selector"},"653":{"id":"/docs/customize/dark-mode-7","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"2\\. Set the initial theme"},"654":{"id":"/docs/customize/dark-mode-8","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"3\\. Add a theme toggle"},"655":{"id":"/docs/customize/dark-mode-9","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#the-usethememode-hook","content":"The useThemeMode hook"},"656":{"id":"/docs/customize/dark-mode-10","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"Dark mode variable overrides"},"657":{"id":"/docs/customize/dark-mode-11","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"Hummingbird uses shared CSS theme variables to power both light and dark modes."},"658":{"id":"/docs/customize/dark-mode-12","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"The default (light) colors are defined in `@theme`."},"659":{"id":"/docs/customize/dark-mode-13","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"The dark palette overrides those same variables inside `@variant dark`."},"660":{"id":"/docs/customize/dark-mode-14","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"Toggling a `.dark` class switches all values globally."},"661":{"id":"/docs/customize/dark-mode-15","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"All components rely on the same semantic tokens:"},"662":{"id":"/docs/customize/dark-mode-16","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--background-color-default`"},"663":{"id":"/docs/customize/dark-mode-17","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--text-color-default`"},"664":{"id":"/docs/customize/dark-mode-18","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--color-primary`"},"665":{"id":"/docs/customize/dark-mode-19","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--border-color-default`"},"666":{"id":"/docs/customize/dark-mode-20","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#result","content":"Switching themes requires no component changes — only variable values update. Every Hummingbird React component adapts automatically."},"667":{"id":"/docs/customize/dark-mode-21","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Override variables after importing Hummingbird:"},"668":{"id":"/docs/customize/dark-mode-22","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"Enable class-based dark mode after importing Tailwind and Hummingbird styles:"},"669":{"id":"/docs/customize/dark-mode-23","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"Render `ThemeModeScript` inside `<head>` to apply the saved theme before first paint — no flash of the wrong theme. Safe in React Server Components."},"670":{"id":"/docs/customize/dark-mode-24","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"`DarkThemeToggle` switches between light and dark mode, persists the choice, and keeps all tabs in sync."},"671":{"id":"/docs/customize/dark-mode-25","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"Pass your own icons to replace the default sun/moon:"},"672":{"id":"/docs/customize/dark-mode-26","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"It is built on Button, so all `Button` props work too."},"673":{"id":"/docs/customize/dark-mode-27","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#the-usethememode-hook","content":"For custom controls, use `useThemeMode`. It applies the `.dark` class, follows the OS preference in `\"system\"` mode, and stays in sync across components and browser tabs. `DarkThemeToggle` uses it internally."},"674":{"id":"/docs/customize/dark-mode-28","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"A list of theme variables that are overridden when dark mode is active."},"675":{"id":"/docs/customize/reboot","page_id":"/docs/customize/reboot","type":"page","content":"Reboot","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/reboot"},"676":{"id":"/docs/customize/reboot-0","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot","content":"Reboot is a file that includes a set of CSS with element-specific changes that gives Hummingbird a clean, consistent starting point for building websites."},"677":{"id":"/docs/customize/reboot-1","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#css-variables","content":"CSS variables"},"678":{"id":"/docs/customize/reboot-2","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#headings","content":"Headings"},"679":{"id":"/docs/customize/reboot-3","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#paragraph","content":"Paragraph"},"680":{"id":"/docs/customize/reboot-4","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#links","content":"Links"},"681":{"id":"/docs/customize/reboot-5","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#buttons","content":"Buttons"},"682":{"id":"/docs/customize/reboot-6","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#horizontal-rules","content":"Horizontal rules"},"683":{"id":"/docs/customize/reboot-7","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#lists","content":"Lists"},"684":{"id":"/docs/customize/reboot-8","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#description-lists","content":"Description lists"},"685":{"id":"/docs/customize/reboot-9","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#code","content":"Code"},"686":{"id":"/docs/customize/reboot-10","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#address","content":"Address"},"687":{"id":"/docs/customize/reboot-11","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#blockquote","content":"Blockquote"},"688":{"id":"/docs/customize/reboot-12","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#legend","content":"Legend"},"689":{"id":"/docs/customize/reboot-13","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#captions","content":"Captions"},"690":{"id":"/docs/customize/reboot-14","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#reboot-css-variables","content":"Reboot CSS variables"},"691":{"id":"/docs/customize/reboot-15","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"CSS variables provide a powerful way to customize and theme projects. It is a feature in modern CSS that allows defining reusable values directly in stylesheets. CSS variables make customization easy: change a value in one place (like `:root`) and it updates everywhere the variable is used. Variables can be set at different levels (global, component, etc.), making them flexible."},"692":{"id":"/docs/customize/reboot-16","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"A \"Reboot\" stylesheet (like Hummingbird's Reboot) resets browser styles and sets up a foundation for consistent design. Using CSS variables in Reboot makes it easy to customize base styles without editing the core CSS — just override the variables."},"693":{"id":"/docs/customize/reboot-17","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Tailwind CSS uses CSS variables for theming and customization. Hummingbird makes use of Tailwind's CSS variable feature to define colors, typography, spacing, and more. This allows projects to easily adapt the design system to specific needs. Learn more about Hummingbird's CSS variables in the Theming section."},"694":{"id":"/docs/customize/reboot-18","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Reboot is included automatically when Hummingbird CSS is imported, so JSX elements rendered by React components get these base styles with no extra setup."},"695":{"id":"/docs/customize/reboot-19","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#headings","content":"All the headings (`h1` to `h6`) in Hummingbird are styled with CSS variables for font size, weight, line height, and margin."},"696":{"id":"/docs/customize/reboot-20","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#paragraph","content":"For all paragraph (`<p>`) elements, `margin-top` was removed, and `margin-bottom: 1rem` is set."},"697":{"id":"/docs/customize/reboot-21","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#links","content":"Links are styled with a default `color` and an `underline`. On hover, the link color changes to a darker shade."},"698":{"id":"/docs/customize/reboot-22","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#buttons","content":"By default, buttons (`<button>`) have a `cursor-pointer` style. When a button is disabled, the cursor changes to `cursor-default`."},"699":{"id":"/docs/customize/reboot-23","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#horizontal-rules","content":"Default `margin-top` and `margin-bottom` for horizontal rules (`<hr>`) is set to `1rem`."},"700":{"id":"/docs/customize/reboot-24","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#lists","content":"By default, unordered lists (`<ul>`) use disc bullets, and ordered lists (`<ol>`) use decimal numbers. Both types of lists have a left padding of `2rem` and a bottom margin of `1rem`. Nested lists have no bottom margin."},"701":{"id":"/docs/customize/reboot-25","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#description-lists","content":"Terms (`<dt>`) are styled with a bold font weight, while descriptions (`<dd>`) use a regular font weight. Default `margin-bottom` for `<dl>` is `1rem`."},"702":{"id":"/docs/customize/reboot-26","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#code","content":"By default, inline code elements (`<code>`) are styled with a specific text color and font size. When a `<code>` element is nested inside an `<a>` tag, it inherits the link's text color and font size."},"703":{"id":"/docs/customize/reboot-27","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#address","content":"The `<address>` element is styled with a bottom margin of `1rem`."},"704":{"id":"/docs/customize/reboot-28","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#blockquote","content":"By default, blockquotes (`<blockquote>`) have a bottom margin of `1rem`."},"705":{"id":"/docs/customize/reboot-29","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#legend","content":"The `<legend>` element is styled to be a block-level element with full width, no padding, and specific margin, font weight, and font size."},"706":{"id":"/docs/customize/reboot-30","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#captions","content":"By default, table captions (`<caption>`) are aligned to the left and positioned at the bottom of the table. They also have specific font weight and padding."},"707":{"id":"/docs/customize/reboot-31","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#reboot-css-variables","content":"The following CSS variables are defined in Hummingbird for reboot styles. Override these variables in the CSS to customize the base styles of the project."},"708":{"id":"/docs/customize/theming","page_id":"/docs/customize/theming","type":"page","content":"Theming","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/theming"},"709":{"id":"/docs/customize/theming-0","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming","content":"Learn how to customize Hummingbird React with Tailwind CSS v4 theme variables, override tokens, and support multiple themes and dark mode."},"710":{"id":"/docs/customize/theming-1","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#overview","content":"Overview"},"711":{"id":"/docs/customize/theming-2","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#available-themes","content":"Available themes"},"712":{"id":"/docs/customize/theming-3","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-themes","content":"How to use themes"},"713":{"id":"/docs/customize/theming-4","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#customizing-theme","content":"Customizing theme"},"714":{"id":"/docs/customize/theming-5","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#spacing","content":"Spacing"},"715":{"id":"/docs/customize/theming-6","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#breakpoints","content":"Breakpoints"},"716":{"id":"/docs/customize/theming-7","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#list-of-theme-variables","content":"List of theme variables"},"717":{"id":"/docs/customize/theming-8","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"How to use multiple themes at once"},"718":{"id":"/docs/customize/theming-9","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#reboot","content":"Reboot"},"719":{"id":"/docs/customize/theming-10","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwinds-helper-functions","content":"Tailwind's helper functions"},"720":{"id":"/docs/customize/theming-11","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--spacing","content":"`--spacing()`"},"721":{"id":"/docs/customize/theming-12","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--alpha","content":"`--alpha()`"},"722":{"id":"/docs/customize/theming-13","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Tailwind theme variable namespaces"},"723":{"id":"/docs/customize/theming-14","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Hummingbird React is styled by Hummingbird CSS, which is built on Tailwind CSS v4 and provides a comprehensive set of theme variables (design tokens) for colors, typography, shadows, and more. Because theming happens entirely in CSS, no React code changes are needed to restyle the components."},"724":{"id":"/docs/customize/theming-15","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Offers multiple prebuilt themes like luxury, retro, arctic etc. These themes are highly customizable, allowing individual tokens to be tweaked or entirely new color palettes to be created to match specific brand aesthetics."},"725":{"id":"/docs/customize/theming-16","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Use the theme variables (like `--color-primary` and `--shadow-md`) via standard Tailwind utilities (for example, `bg-primary`, `text-primary`, `shadow-md`)."},"726":{"id":"/docs/customize/theming-17","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Override any theme variables globally by redefining them in an `@theme { ... }` block after importing the CSS."},"727":{"id":"/docs/customize/theming-18","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Reboot provides a base CSS reset with element-specific styles for consistent design across browsers."},"728":{"id":"/docs/customize/theming-19","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Here is a quick overview of the available prebuilt themes:"},"729":{"id":"/docs/customize/theming-20","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"The signature Hummingbird theme with balanced neutrals and vibrant blue\naccents."},"730":{"id":"/docs/customize/theming-21","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Rich maroon and golden tones crafted for a refined, premium appearance."},"731":{"id":"/docs/customize/theming-22","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm vintage-inspired colors that bring a classic and timeless feel."},"732":{"id":"/docs/customize/theming-23","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Cool blues and frosty tones inspired by modern winter landscapes."},"733":{"id":"/docs/customize/theming-24","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Fresh greens and earthy shades inspired by the natural world."},"734":{"id":"/docs/customize/theming-25","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep purples and vivid pinks designed for bold, high-contrast\ninterfaces."},"735":{"id":"/docs/customize/theming-26","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm oranges and amber tones that create an energetic, glowing\naesthetic."},"736":{"id":"/docs/customize/theming-27","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep blues and indigos designed for calm, modern dark experiences."},"737":{"id":"/docs/customize/theming-28","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"By default, Hummingbird includes the `default` theme. To use a different prebuilt theme, simply import the corresponding CSS file in the main CSS file (e.g., `globals.css`). Each theme has built-in dark mode support, so dark mode will automatically work when the theme is imported."},"738":{"id":"/docs/customize/theming-29","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"Only one theme should be imported at a time, as importing multiple themes will cause the last one to override the others."},"739":{"id":"/docs/customize/theming-30","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#customizing-theme","content":"Redefine theme variables by declaring them in `@theme` after importing Hummingbird:"},"740":{"id":"/docs/customize/theming-31","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#spacing","content":"Customize spacing by overriding the default spacing variable or defining new ones as needed."},"741":{"id":"/docs/customize/theming-32","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#breakpoints","content":"Customize and add new responsive breakpoints by overriding `--breakpoint-*` variables:"},"742":{"id":"/docs/customize/theming-33","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#list-of-theme-variables","content":"Hummingbird provides a small, consistent set of semantic theme variables. These variables create utilities and can be overridden later to change the look and feel without changing any component code. See dark mode variable overrides here."},"743":{"id":"/docs/customize/theming-34","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Hummingbird uses a small set of theme variables. By overriding these variables within a new theme scope, multiple themes can be created."},"744":{"id":"/docs/customize/theming-35","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Create a custom variant for the new themes."},"745":{"id":"/docs/customize/theming-36","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Define the theme variables within the new variant scope. To use an existing theme's colors, simply copy all the variables from the c