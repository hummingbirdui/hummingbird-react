ing","tags":[],"url":"/docs/layout/grid#row-columns-gutters","content":"Row columns gutters"},"404":{"id":"/docs/layout/grid-20","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#no-gutters","content":"No gutters"},"405":{"id":"/docs/layout/grid-21","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#api-reference","content":"API Reference"},"406":{"id":"/docs/layout/grid-22","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row","content":"Row"},"407":{"id":"/docs/layout/grid-23","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#col","content":"Col"},"408":{"id":"/docs/layout/grid-24","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#css-variables","content":"CSS variables"},"409":{"id":"/docs/layout/grid-25","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#styling","content":"Styling"},"410":{"id":"/docs/layout/grid-26","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#basic-example","content":"The Grid uses the `Container`, `Row`, and `Col` components to create responsive layouts. It is built with flexbox and adapts to different screen sizes."},"411":{"id":"/docs/layout/grid-27","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#auto-layout-columns","content":"Breakpoint props allow easy sizing of columns without setting an explicit numbered span."},"412":{"id":"/docs/layout/grid-28","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#equal-width","content":"A `Col` without any props creates equal-width columns for every screen size."},"413":{"id":"/docs/layout/grid-29","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#variable-width-content","content":"Setting a breakpoint prop to `\"auto\"` sizes the column based on the natural width of its content."},"414":{"id":"/docs/layout/grid-30","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#responsive-props","content":"The `xs`, `sm`, `md`, `lg`, `xl`, and `xxl` props specify different column sizes for different screen sizes. Breakpoints are defined using minimum widths, meaning each one applies from that width upward. For example, `md={4}` applies to medium devices (tablets) and above, and renders the `md:col-4` class."},"415":{"id":"/docs/layout/grid-31","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#all-breakpoints","content":"For grids that are the same across all breakpoints, plain `Col` and the `xs` prop are enough."},"416":{"id":"/docs/layout/grid-32","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#mix-and-match","content":"Different breakpoint props can be combined on the same column for different screen sizes."},"417":{"id":"/docs/layout/grid-33","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns","content":"Instead of sizing each column, the `Row` breakpoint props set the number of columns per row. The grid automatically lays out the columns evenly, and `\"auto\"` sizes them based on their content."},"418":{"id":"/docs/layout/grid-34","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#nesting","content":"Nesting works by placing a new `Row` and set of `Col` components inside an existing `Col`. This gives more control over the layout of the content."},"419":{"id":"/docs/layout/grid-35","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#columns","content":"Columns can be modified with options for alignment, ordering, and offsetting using the flexbox grid system."},"420":{"id":"/docs/layout/grid-36","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `items-start`, `items-center`, and `items-end` classes on `Row` control vertical alignment of all columns."},"421":{"id":"/docs/layout/grid-37","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `self-start`, `self-center`, and `self-end` classes control vertical alignment of individual columns."},"422":{"id":"/docs/layout/grid-38","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-alignment","content":"The `justify-*` classes on `Row` control horizontal alignment."},"423":{"id":"/docs/layout/grid-39","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#order-classes","content":"The `order-{number}` classes change the visual order of columns."},"424":{"id":"/docs/layout/grid-40","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#offsetting-columns","content":"The object form of a breakpoint prop moves columns to the right. For example, `md={{ span: 4, offset: 4 }}` renders the `md:col-4 md:offset-4` classes, moving the column over four columns on medium screens and larger."},"425":{"id":"/docs/layout/grid-41","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#gutters","content":"Gutters are the spacing between columns, used to create consistent spacing and alignment in the grid system. Hummingbird supports gutter utilities up to `g-24` (6rem), applied to `Row` through the `className` prop."},"426":{"id":"/docs/layout/grid-42","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-gutters","content":"The `gx-{size}` classes set horizontal gutters between columns."},"427":{"id":"/docs/layout/grid-43","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-gutters","content":"The `gy-{size}` classes set vertical gutters between rows."},"428":{"id":"/docs/layout/grid-44","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal--vertical-gutters","content":"The `g-{size}` classes set both horizontal and vertical gutters."},"429":{"id":"/docs/layout/grid-45","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns-gutters","content":"Gutter classes can be combined with the `Row` breakpoint props to create gutters between rows and columns."},"430":{"id":"/docs/layout/grid-46","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#no-gutters","content":"The `g-0` class removes all gutters between rows and columns."},"431":{"id":"/docs/layout/grid-47","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#api-reference","content":"The grid components are available from `@hummingbirdui/react` or the `@hummingbirdui/react/layout/grid` subpath. All three render a `<div>` and accept standard div attributes."},"432":{"id":"/docs/layout/grid-48","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#css-variables","content":"The Grid uses CSS variables for easy customization. Override these variables in the CSS to change the grid's behavior."},"433":{"id":"/docs/layout/grid-49","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#styling","content":"Hummingbird React grid components are styled entirely through Hummingbird's grid classes and CSS variables. See the Hummingbird Grid documentation for the full class reference."},"434":{"id":"/docs/layout/text","page_id":"/docs/layout/text","type":"page","content":"Text","breadcrumbs":["Docs","Layout & Content"],"tags":[],"url":"/docs/layout/text"},"435":{"id":"/docs/layout/text-0","page_id":"/docs/layout/text","tags":[],"type":"text","url":"/docs/layout/text","content":"Text is a polymorphic typography component for rendering any text element with consistent size, weight, and overflow handling."},"436":{"id":"/docs/layout/text-1","page_id":"/docs/layout/text","type":"heading","tags":[],"url":"/docs/layout/text#default","content":"Default"},"437":{"id":"/docs/layou