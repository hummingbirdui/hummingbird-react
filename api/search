ustomize/component","tags":[],"type":"text","url":"/docs/customize/component#using-css-variables","content":"For example, to update or customize the Button component, override its CSS variables:"},"49":{"id":"/docs/customize/component-13","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-1-global-variables","content":"Override the theme variables globally under `@theme`. This will apply the changes across all components in the project."},"50":{"id":"/docs/customize/component-14","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"Override the component variables locally under the component's class or a custom class. This will apply the changes only to that specific component."},"51":{"id":"/docs/customize/component-15","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"To scope the change to only some buttons, pass a custom class through the `className` prop and target that class in CSS."},"52":{"id":"/docs/customize/dark-mode","page_id":"/docs/customize/dark-mode","type":"page","content":"Dark Mode","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/dark-mode"},"53":{"id":"/docs/customize/dark-mode-0","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode","content":"This guide explains how to enable and manage dark mode in a React application, in a way consistent with Tailwind's dark-mode documentation."},"54":{"id":"/docs/customize/dark-mode-1","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#how-it-works","content":"How it works"},"55":{"id":"/docs/customize/dark-mode-2","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#key-idea","content":"Key idea"},"56":{"id":"/docs/customize/dark-mode-3","page_id":