stomize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"It is recommended to rely on semantic color classes. Semantic colors are mapped to design tokens and automatically adapt when themes change."},"570":{"id":"/docs/customize/colors-12","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"For example,"},"571":{"id":"/docs/customize/colors-13","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`text-primary`"},"572":{"id":"/docs/customize/colors-14","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`bg-subtle`"},"573":{"id":"/docs/customize/colors-15","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`border-subtle` etc."},"574":{"id":"/docs/customize/colors-16","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"This approach prevents dependence on specific palette values (`blue-500`, `green-600`, etc.). Instead, components reference semantic roles (`primary`, `secondary`, `warning`), making the UI easier to maintain, brand, and theme."},"575":{"id":"/docs/customize/colors-17","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"Behind the scenes, each semantic color class points to a CSS variable. Updating or overriding that variable updates the color everywhere it is used — including inside every Hummingbird React component."},"576":{"id":"/docs/customize/colors-18","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Here is the list of semantic colors that will be generated as Tailwind utilities and also available as CSS variables."},"577":{"id":"/docs/customize/colors-19","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Background colors"},"578":{"id":"/docs/customize/colors-20","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Text colors"},"579":{"id":"/docs/customize/colors-21","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Border colors"},"580":{"id":"/docs/customize/colors-22","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Actions colors (generate all color-related utilities)"},"581":{"id":"/docs/customize/colors-23","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Theme colors (generate all color-related utilities)"},"582":{"id":"/docs/customize/colors-24","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Contrast"},"583":{"id":"/docs/customize/colors-25","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"Use semantic color classes like:"},"584":{"id":"/docs/customize/colors-26","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`bg-primary`"},"585":{"id":"/docs/customize/colors-27","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`text-muted`"},"586":{"id":"/docs/customize/colors-28","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"`border-default`"},"587":{"id":"/docs/customize/colors-29","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#how-to-use","content":"These classes use the theme's color variables, so the UI stays consistent when customizing or switching themes. They can be applied to any element or passed to any component through the `className` prop."},"588":{"id":"/docs/customize/colors-30","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#customize-color","content":"Override any theme color or palette color by redefining its CSS variable inside a `@theme` block after importing Hummingbird:"},"589":{"id":"/docs/customize/colors-31","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#color-palettes","content":"Each Hummingbird theme includes its own complete color palette, carefully designed to maintain a consistent visual tone. Use these palettes to customize existing themes or create entirely new ones with confidence. Hover a swatch to see its OKLCH value, and click to copy it."},"590":{"id":"/docs/customize/colors-32","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#default-color-palette-reference","content":"Here's a complete list of the default colors and their values for reference:"},"591":{"id":"/docs/customize/component","page_id":"/docs/customize/component","type":"page","content":"Component Customization","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/component"},"592":{"id":"/docs/customize/component-0","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component","content":"Hummingbird React components can be customized using props, utility classes, or CSS variables to match specific design needs."},"593":{"id":"/docs/customize/component-1","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-props","content":"Using props"},"594":{"id":"/docs/customize/component-2","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-tailwind-utility-classes","content":"Using Tailwind utility classes"},"595":{"id":"/docs/customize/component-3","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-the-apply-directive","content":"Using the `@apply` directive"},"596":{"id":"/docs/customize/component-4","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#using-css-variables","content":"Using CSS variables"},"597":{"id":"/docs/customize/component-5","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#option-1-global-variables","content":"Option 1: Global variables"},"598":{"id":"/docs/customize/component-6","page_id":"/docs/customize/component","type":"heading","tags":[],"url":"/docs/customize/component#option-2-local-variables","content":"Option 2: Local variables"},"599":{"id":"/docs/customize/component-7","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-props","content":"Every Hummingbird React component ships with variants that are controlled through props. This is the first and simplest level of customization. For example, the button component can be adjusted with the `variant`, `color`, `size`, and `shape` props."},"600":{"id":"/docs/customize/component-8","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-props","content":"The available props for each component are listed in the API Reference section of its documentation page."},"601":{"id":"/docs/customize/component-9","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-tailwind-utility-classes","content":"All components accept a `className` prop. Custom classes are merged with the component classes, so any Tailwind utility can be applied on top. For example, rounded pill buttons can be created by adding the `rounded-full` class."},"602":{"id":"/docs/customize/component-10","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-the-apply-directive","content":"Customization can also be done in a CSS file using Tailwind CSS's `@apply` directive. Because the components render Hummingbird's CSS classes (such as `btn`), overriding the class changes every instance of the component."},"603":{"id":"/docs/customize/component-11","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-css-variables","content":"Hummingbird components are styled with a set of CSS variables. These variables make it easy to customize styles either globally (across the entire project) or locally (for a specific component)."},"604":{"id":"/docs/customize/component-12","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#using-css-variables","content":"For example, to update or customize the Button component, override its CSS variables:"},"605":{"id":"/docs/customize/component-13","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-1-global-variables","content":"Override the theme variables globally under `@theme`. This will apply the changes across all components in the project."},"606":{"id":"/docs/customize/component-14","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"Override the component variables locally under the component's class or a custom class. This will apply the changes only to that specific component."},"607":{"id":"/docs/customize/component-15","page_id":"/docs/customize/component","tags":[],"type":"text","url":"/docs/customize/component#option-2-local-variables","content":"To scope the change to only some buttons, pass a custom class through the `className` prop and target that class in CSS."},"608":{"id":"/docs/customize/dark-mode","page_id":"/docs/customize/dark-mode","type":"page","content":"Dark Mode","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/dark-mode"},"609":{"id":"/docs/customize/dark-mode-0","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode","content":"This guide explains how to enable and manage dark mode in a React application, in a way consistent with Tailwind's dark-mode documentation."},"610":{"id":"/docs/customize/dark-mode-1","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#how-it-works","content":"How it works"},"611":{"id":"/docs/customize/dark-mode-2","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#key-idea","content":"Key idea"},"612":{"id":"/docs/customize/dark-mode-3","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#result","content":"Result"},"613":{"id":"/docs/customize/dark-mode-4","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Customizing dark mode"},"614":{"id":"/docs/customize/dark-mode-5","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#setting-up-dark-mode","content":"Setting up dark mode"},"615":{"id":"/docs/customize/dark-mode-6","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"1\\. Custom dark mode selector"},"616":{"id":"/docs/customize/dark-mode-7","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"2\\. Set the initial theme"},"617":{"id":"/docs/customize/dark-mode-8","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"3\\. Add a theme toggle"},"618":{"id":"/docs/customize/dark-mode-9","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#the-usethememode-hook","content":"The useThemeMode hook"},"619":{"id":"/docs/customize/dark-mode-10","page_id":"/docs/customize/dark-mode","type":"heading","tags":[],"url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"Dark mode variable overrides"},"620":{"id":"/docs/customize/dark-mode-11","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"Hummingbird uses shared CSS theme variables to power both light and dark modes."},"621":{"id":"/docs/customize/dark-mode-12","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"The default (light) colors are defined in `@theme`."},"622":{"id":"/docs/customize/dark-mode-13","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"The dark palette overrides those same variables inside `@variant dark`."},"623":{"id":"/docs/customize/dark-mode-14","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"Toggling a `.dark` class switches all values globally."},"624":{"id":"/docs/customize/dark-mode-15","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"All components rely on the same semantic tokens:"},"625":{"id":"/docs/customize/dark-mode-16","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--background-color-default`"},"626":{"id":"/docs/customize/dark-mode-17","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--text-color-default`"},"627":{"id":"/docs/customize/dark-mode-18","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--color-primary`"},"628":{"id":"/docs/customize/dark-mode-19","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--border-color-default`"},"629":{"id":"/docs/customize/dark-mode-20","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#result","content":"Switching themes requires no component changes — only variable values update. Every Hummingbird React component adapts automatically."},"630":{"id":"/docs/customize/dark-mode-21","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Override variables after importing Hummingbird:"},"631":{"id":"/docs/customize/dark-mode-22","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"Enable class-based dark mode after importing Tailwind and Hummingbird styles:"},"632":{"id":"/docs/customize/dark-mode-23","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"Render `ThemeModeScript` inside `<head>` to apply the saved theme before first paint — no flash of the wrong theme. Safe in React Server Components."},"633":{"id":"/docs/customize/dark-mode-24","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"`DarkThemeToggle` switches between light and dark mode, persists the choice, and keeps all tabs in sync."},"634":{"id":"/docs/customize/dark-mode-25","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"Pass your own icons to replace the default sun/moon:"},"635":{"id":"/docs/customize/dark-mode-26","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"It is built on Button, so all `Button` props work too."},"636":{"id":"/docs/customize/dark-mode-27","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#the-usethememode-hook","content":"For custom controls, use `useThemeMode`. It applies the `.dark` class, follows the OS preference in `\"system\"` mode, and stays in sync across components and browser tabs. `DarkThemeToggle` uses it internally."},"637":{"id":"/docs/customize/dark-mode-28","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"A list of theme variables that are overridden when dark mode is active."},"638":{"id":"/docs/customize/reboot","page_id":"/docs/customize/reboot","type":"page","content":"Reboot","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/reboot"},"639":{"id":"/docs/customize/reboot-0","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot","content":"Reboot is a file that includes a set of CSS with element-specific changes that gives Hummingbird a clean, consistent starting point for building websites."},"640":{"id":"/docs/customize/reboot-1","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#css-variables","content":"CSS variables"},"641":{"id":"/docs/customize/reboot-2","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#headings","content":"Headings"},"642":{"id":"/docs/customize/reboot-3","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#paragraph","content":"Paragraph"},"643":{"id":"/docs/customize/reboot-4","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#links","content":"Links"},"644":{"id":"/docs/customize/reboot-5","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#buttons","content":"Buttons"},"645":{"id":"/docs/customize/reboot-6","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#horizontal-rules","content":"Horizontal rules"},"646":{"id":"/docs/customize/reboot-7","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#lists","content":"Lists"},"647":{"id":"/docs/customize/reboot-8","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#description-lists","content":"Description lists"},"648":{"id":"/docs/customize/reboot-9","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#code","content":"Code"},"649":{"id":"/docs/customize/reboot-10","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#address","content":"Address"},"650":{"id":"/docs/customize/reboot-11","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#blockquote","content":"Blockquote"},"651":{"id":"/docs/customize/reboot-12","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#legend","content":"Legend"},"652":{"id":"/docs/customize/reboot-13","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#captions","content":"Captions"},"653":{"id":"/docs/customize/reboot-14","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#reboot-css-variables","content":"Reboot CSS variables"},"654":{"id":"/docs/customize/reboot-15","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"CSS variables provide a powerful way to customize and theme projects. It is a feature in modern CSS that allows defining reusable values directly in stylesheets. CSS variables make customization easy: change a value in one place (like `:root`) and it updates everywhere the variable is used. Variables can be set at different levels (global, component, etc.), making them flexible."},"655":{"id":"/docs/customize/reboot-16","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"A \"Reboot\" stylesheet (like Hummingbird's Reboot) resets browser styles and sets up a foundation for consistent design. Using CSS variables in Reboot makes it easy to customize base styles without editing the core CSS — just override the variables."},"656":{"id":"/docs/customize/reboot-17","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Tailwind CSS uses CSS variables for theming and customization. Hummingbird makes use of Tailwind's CSS variable feature to define colors, typography, spacing, and more. This allows projects to easily adapt the design system to specific needs. Learn more about Hummingbird's CSS variables in the Theming section."},"657":{"id":"/docs/customize/reboot-18","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Reboot is included automatically when Hummingbird CSS is imported, so JSX elements rendered by React components get these base styles with no extra setup."},"658":{"id":"/docs/customize/reboot-19","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#headings","content":"All the headings (`h1` to `h6`) in Hummingbird are styled with CSS variables for font size, weight, line height, and margin."},"659":{"id":"/docs/customize/reboot-20","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#paragraph","content":"For all paragraph (`<p>`) elements, `margin-top` was removed, and `margin-bottom: 1rem` is set."},"660":{"id":"/docs/customize/reboot-21","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#links","content":"Links are styled with a default `color` and an `underline`. On hover, the link color changes to a darker shade."},"661":{"id":"/docs/customize/reboot-22","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#buttons","content":"By default, buttons (`<button>`) have a `cursor-pointer` style. When a button is disabled, the cursor changes to `cursor-default`."},"662":{"id":"/docs/customize/reboot-23","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#horizontal-rules","content":"Default `margin-top` and `margin-bottom` for horizontal rules (`<hr>`) is set to `1rem`."},"663":{"id":"/docs/customize/reboot-24","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#lists","content":"By default, unordered lists (`<ul>`) use disc bullets, and ordered lists (`<ol>`) use decimal numbers. Both types of lists have a left padding of `2rem` and a bottom margin of `1rem`. Nested lists have no bottom margin."},"664":{"id":"/docs/customize/reboot-25","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#description-lists","content":"Terms (`<dt>`) are styled with a bold font weight, while descriptions (`<dd>`) use a regular font weight. Default `margin-bottom` for `<dl>` is `1rem`."},"665":{"id":"/docs/customize/reboot-26","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#code","content":"By default, inline code elements (`<code>`) are styled with a specific text color and font size. When a `<code>` element is nested inside an `<a>` tag, it inherits the link's text color and font size."},"666":{"id":"/docs/customize/reboot-27","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#address","content":"The `<address>` element is styled with a bottom margin of `1rem`."},"667":{"id":"/docs/customize/reboot-28","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#blockquote","content":"By default, blockquotes (`<blockquote>`) have a bottom margin of `1rem`."},"668":{"id":"/docs/customize/reboot-29","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#legend","content":"The `<legend>` element is styled to be a block-level element with full width, no padding, and specific margin, font weight, and font size."},"669":{"id":"/docs/customize/reboot-30","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#captions","content":"By default, table captions (`<caption>`) are aligned to the left and positioned at the bottom of the table. They also have specific font weight and padding."},"670":{"id":"/docs/customize/reboot-31","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#reboot-css-variables","content":"The following CSS variables are defined in Hummingbird for reboot styles. Override these variables in the CSS to customize the base styles of the project."},"671":{"id":"/docs/customize/theming","page_id":"/docs/customize/theming","type":"page","content":"Theming","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/theming"},"672":{"id":"/docs/customize/theming-0","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming","content":"Learn how to customize Hummingbird React with Tailwind CSS v4 theme variables, override tokens, and support multiple themes and dark mode."},"673":{"id":"/docs/customize/theming-1","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#overview","content":"Overview"},"674":{"id":"/docs/customize/theming-2","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#available-themes","content":"Available themes"},"675":{"id":"/docs/customize/theming-3","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-themes","content":"How to use themes"},"676":{"id":"/docs/customize/theming-4","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#customizing-theme","content":"Customizing theme"},"677":{"id":"/docs/customize/theming-5","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#spacing","content":"Spacing"},"678":{"id":"/docs/customize/theming-6","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#breakpoints","content":"Breakpoints"},"679":{"id":"/docs/customize/theming-7","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#list-of-theme-variables","content":"List of theme variables"},"680":{"id":"/docs/customize/theming-8","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"How to use multiple themes at once"},"681":{"id":"/docs/customize/theming-9","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#reboot","content":"Reboot"},"682":{"id":"/docs/customize/theming-10","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwinds-helper-functions","content":"Tailwind's helper functions"},"683":{"id":"/docs/customize/theming-11","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--spacing","content":"`--spacing()`"},"684":{"id":"/docs/customize/theming-12","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--alpha","content":"`--alpha()`"},"685":{"id":"/docs/customize/theming-13","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Tailwind theme variable namespaces"},"686":{"id":"/docs/customize/theming-14","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Hummingbird React is styled by Hummingbird CSS, which is built on Tailwind CSS v4 and provides a comprehensive set of theme variables (design tokens) for colors, typography, shadows, and more. Because theming happens entirely in CSS, no React code changes are needed to restyle the components."},"687":{"id":"/docs/customize/theming-15","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Offers multiple prebuilt themes like luxury, retro, arctic etc. These themes are highly customizable, allowing individual tokens to be tweaked or entirely new color palettes to be created to match specific brand aesthetics."},"688":{"id":"/docs/customize/theming-16","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Use the theme variables (like `--color-primary` and `--shadow-md`) via standard Tailwind utilities (for example, `bg-primary`, `text-primary`, `shadow-md`)."},"689":{"id":"/docs/customize/theming-17","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Override any theme variables globally by redefining them in an `@theme { ... }` block after importing the CSS."},"690":{"id":"/docs/customize/theming-18","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Reboot provides a base CSS reset with element-specific styles for consistent design across browsers."},"691":{"id":"/docs/customize/theming-19","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Here is a quick overview of the available prebuilt themes:"},"692":{"id":"/docs/customize/theming-20","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"The signature Hummingbird theme with balanced neutrals and vibrant blue\naccents."},"693":{"id":"/docs/customize/theming-21","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Rich maroon and golden tones crafted for a refined, premium appearance."},"694":{"id":"/docs/customize/theming-22","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm vintage-inspired colors that bring a classic and timeless feel."},"695":{"id":"/docs/customize/theming-23","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Cool blues and frosty tones inspired by modern winter landscapes."},"696":{"id":"/docs/customize/theming-24","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Fresh greens and earthy shades inspired by the natural world."},"697":{"id":"/docs/customize/theming-25","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep purples and vivid pinks designed for bold, high-contrast\ninterfaces."},"698":{"id":"/docs/customize/theming-26","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm oranges and amber tones that create an energetic, glowing\naesthetic."},"699":{"id":"/docs/customize/theming-27","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep blues and indigos designed for calm, modern dark experiences."},"700":{"id":"/docs/customize/theming-28","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"By default, Hummingbird includes the `default` theme. To use a different prebuilt theme, simply import the corresponding CSS file in the main CSS file (e.g., `globals.css`). Each theme has built-in dark mode support, so dark mode will automatically work when the theme is imported."},"701":{"id":"/docs/customize/theming-29","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"Only one theme should be imported at a time, as importing multiple themes will cause the last one to override the others."},"702":{"id":"/docs/customize/theming-30","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#customizing-theme","content":"Redefine theme variables by declaring them in `@theme` after importing Hummingbird:"},"703":{"id":"/docs/customize/theming-31","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#spacing","content":"Customize spacing by overriding the default spacing variable or defining new ones as needed."},"704":{"id":"/docs/customize/theming-32","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#breakpoints","content":"Customize and add new responsive breakpoints by overriding `--breakpoint-*` variables:"},"705":{"id":"/docs/customize/theming-33","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#list-of-theme-variables","content":"Hummingbird provides a small, consistent set of semantic theme variables. These variables create utilities and can be overridden later to change the look and feel without changing any component code. See dark mode variable overrides here."},"706":{"id":"/docs/customize/theming-34","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Hummingbird uses a small set of theme variables. By overriding these variables within a new theme scope, multiple themes can be created."},"707":{"id":"/docs/customize/theming-35","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Create a custom variant for the new themes."},"708":{"id":"/docs/customize/theming-36","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Define the theme variables within the new variant scope. To use an existing theme's colors, simply copy all the variables from the corresponding Hummingbird theme file and paste them into the new variant scope."},"709":{"id":"/docs/customize/theming-37","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#reboot","content":"Reboot is a foundational stylesheet that resets browser defaults and applies basic element styles. It provides a clean, consistent starting point for building interfaces and ensures visual consistency across browsers."},"710":{"id":"/docs/customize/theming-38","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#reboot","content":"For more details, follow the Reboot documentation."},"711":{"id":"/docs/customize/theming-39","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwinds-helper-functions","content":"Tailwind provides the following build-time functions to make working with colors and the spacing scale easier."},"712":{"id":"/docs/customize/theming-40","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#--spacing","content":"Use this function to generate a spacing value based on the theme:"},"713":{"id":"/docs/customize/theming-41","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#--alpha","content":"Use this function to adjust the opacity of a color:"},"714":{"id":"/docs/customize/theming-42","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Tailwind theme variables are defined in namespaces, and each namespace corresponds to one or more utility classes or variant APIs."},"715":{"id":"/docs/customize/theming-43","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Defining new theme variables in these namespaces will make new corresponding utilities and variants available in the project:"},"716":{"id":"/docs/customize/theming-44","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Color utilities like `bg-primary-light`, `text-primary-dark`, and many\nmore"},"717":{"id":"/docs/customize/theming-45","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Text color utilities like `text-default`, `text-subtle`, and many more"},"718":{"id":"/docs/customize/theming-46","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Background color utilities like `bg-highlight`, `bg-emphasis`, and many\nmore"},"719":{"id":"/docs/customize/theming-47","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Border color utilities like `border-default`, `border-subtle`, and many\nmore"},"720":{"id":"/docs/customize/theming-48","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Container query variants like `@sm:*` and size utilities like `max-w-md`"},"721":{"id":"/docs/customize/theming-49","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Spacing and sizing utilities like `px-4`, `max-h-16`, and many more"},"722":{"id":"/docs/customize/theming-50","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Transition timing function utilities like `ease-out`"},"723":{"id":"/docs/customize/theming-51","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Follow the official Tailwind CSS docs for more details."},"724":{"id":"/docs/customize/utilities","page_id":"/docs/customize/utilities","type":"page","content":"Utilities","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/utilities"},"725":{"id":"/docs/customize/utilities-0","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"Frequently used utilities for customizing Hummingbird React components."},"726":{"id":"/docs/customize/utilities-1","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#padding","content":"Padding"},"727":{"id":"/docs/customize/utilities-2","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#margin","content":"Margin"},"728":{"id":"/docs/customize/utilities-3","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#font-family","content":"Font family"},"729":{"id":"/docs/customize/utilities-4","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#font-size","content":"Font size"},"730":{"id":"/docs/customize/utilities-5","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#font-weight","content":"Font weight"},"731":{"id":"/docs/customize/utilities-6","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#line-height","content":"Line height"},"732":{"id":"/docs/customize/utilities-7","page_id":"/docs/customize/utilities","type":"heading","tags":[],"url":"/docs/customize/utilities#border-radius","content":"Border radius"},"733":{"id":"/docs/customize/utilities-8","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"All Tailwind utility classes can be applied to Hummingbird React components through the `className` prop. Custom classes are merged with the component classes, so utilities can adjust spacing, typography, radius, and more without writing custom CSS. This page lists the most frequently used utilities; see the official Tailwind CSS docs for the complete reference."},"734":{"id":"/docs/customize/utilities-9","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"Each utility supports these value forms:"},"735":{"id":"/docs/customize/utilities-10","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"`p-4` — a number, multiplied by the `--spacing` scale (where applicable)"},"736":{"id":"/docs/customize/utilities-11","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"`p-px` — a fixed `1px` value"},"737":{"id":"/docs/customize/utilities-12","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"`p-(--my-padding)` — a custom CSS property"},"738":{"id":"/docs/customize/utilities-13","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities","content":"`p-[12px]` — an arbitrary value"},"739":{"id":"/docs/customize/utilities-14","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#padding","content":"Utilities for controlling the padding of an element."},"740":{"id":"/docs/customize/utilities-15","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#margin","content":"Utilities for controlling the margin of an element. Negative values (e.g., `-mt-4`) and `auto` (e.g., `mx-auto`) are also supported."},"741":{"id":"/docs/customize/utilities-16","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#font-family","content":"Utilities for controlling the font family of an element."},"742":{"id":"/docs/customize/utilities-17","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#font-size","content":"Utilities for controlling the font size of an element. Each size also sets a matching line height."},"743":{"id":"/docs/customize/utilities-18","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#font-weight","content":"Utilities for controlling the font weight of an element."},"744":{"id":"/docs/customize/utilities-19","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#line-height","content":"Utilities for controlling the line height of an element."},"745":{"id":"/docs/customize/utilities-20","page_id":"/docs/customize/utilities","tags":[],"type":"text","url":"/docs/customize/utilities#border-radius","content":"Utilities for controlling the border radius of an element. Side-specific variants (`rounded-t-*`, `rounded-s-*`, `rounded-tl-*`, etc.) are also available for every size."},"746":{"id":"/docs/getting-started/installation","page_id":"/docs/getting-started/installation","type":"page","content":"Installation","breadcrumbs":["Docs","Getting Started"],"tags":[],"url":"/docs/getting-started/installation"},"747":{"id":"/docs/getting-started/installation-0","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation","content":"Install Hummingbird React and set it up in your project."},"748":{"id":"/docs/getting-started/installation-1","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#installation","content":"Installation"},"749":{"id":"/docs/getting-started/installation-2","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#1-install-tailwind-css","content":"1\\. Install Tailwind CSS"},"750":{"id":"/docs/getting-started/installation-3","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#2-install-hummingbird-react","content":"2\\. Install Hummingbird React"},"751":{"id":"/docs/getting-started/installation-4","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#3-import-css","content":"3\\. Import CSS"},"752":{"id":"/docs/getting-started/installation-5","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#4-use-components","content":"4\\. Use components"},"753":{"id":"/docs/getting-started/installation-6","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#typescript-support","content":"TypeScript support"},"754":{"id":"/docs/getting-started/installation-7","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#customization","content":"Customization"},"755":{"id":"/docs/getting-started/installation-8","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#1-install-tailwind-css","content":"Ensure the project is set up with Tailwind CSS. If Tailwind CSS hasn't been set up yet, follow the official installation guide."},"756":{"id":"/docs/getting-started/installation-9","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#2-install-hummingbird-react","content":"Install Hummingbird React via a preferred package manager. The `@hummingbirdui/hummingbird` package provides the styles and is required as a peer dependency."},"757":{"id":"/docs/getting-started/installation-10","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"Import Hummingbird styles in the main CSS file (e.g., `globals.css`), and register the package as a source so the Tailwind compiler scans it for class names."},"758":{"id":"/docs/getting-started/installation-11","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"The `@source` directive is required because Tailwind does not scan node\\_modules by default. Since Hummingbird generates component classes on demand, Tailwind must scan the `@hummingbirdui/react` package. Update the relative path so it points to node\\_modules from your CSS file."},"759":{"id":"/docs/getting-started/installation-12","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#3-import-css","content":"No per-component CSS imports or manual purge configuration are needed."},"760":{"id":"/docs/getting-started/installation-13","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#4-use-components","content":"Import any component and use it in the application."},"761":{"id":"/docs/getting-started/installation-14","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#typescript-support","content":"Hummingbird React is written in TypeScript and includes type definitions for all components. Component props are fully typed, so no additional `@types` packages are needed."},"762":{"id":"/docs/getting-started/installation-15","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"All components accept a `className` prop. Custom classes are merged with the component classes, so Tailwind utility classes can be used to adjust any component."},"763":{"id":"/docs/getting-started/installation-16","page_id":"/docs/getting-started/installation","tags":[],"type":"text","url":"/docs/getting-started/installation#customization","content":"For theme-level changes such as colors and spacing, Hummingbird provides global and component-specific CSS variables. See the Customize section for details."},"764":{"id":"/docs/getting-started/introduction","page_id":"/docs/getting-started/introduction","type":"page","content":"Introduction","breadcrumbs":["Docs","Getting Started"],"tags":[],"url":"/docs/getting-started/introduction"},"765":{"id":"/docs/getting-started/introduction-0","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction","content":"Welcome to the Hummingbird React documentation. It is an open-source React component library built on Hummingbird CSS and Radix UI primitives."},"766":{"id":"/docs/getting-started/introduction-1","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"What is Hummingbird React?"},"767":{"id":"/docs/getting-started/introduction-2","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Why Hummingbird React?"},"768":{"id":"/docs/getting-started/introduction-3","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"Pre-requisite knowledge"},"769":{"id":"/docs/getting-started/introduction-4","page_id":"/docs/getting-started/introduction","type":"heading","tags":[],"url":"/docs/getting-started/introduction#join-our-community","content":"Join our community"},"770":{"id":"/docs/getting-started/introduction-5","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"Hummingbird React is the official React component library for the Hummingbird design system. It provides a large set of accessible, fully styled React components such as buttons, forms, dialogs, and dropdowns, along with patterns suitable for dashboards, SaaS applications, and e-commerce systems."},"771":{"id":"/docs/getting-started/introduction-6","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#what-is-hummingbird-react","content":"The library follows one core principle: **Hummingbird CSS owns the visuals, and Radix UI owns the behavior**. Every component is styled with Hummingbird's component classes on top of Tailwind CSS, while interactive components use Radix UI primitives for keyboard navigation, focus management, and accessibility. Hummingbird React is the bridge between the two."},"772":{"id":"/docs/getting-started/introduction-7","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides ready-to-use React components with a consistent, typed API."},"773":{"id":"/docs/getting-started/introduction-8","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Ships accessible behavior out of the box through Radix UI primitives."},"774":{"id":"/docs/getting-started/introduction-9","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Reduces reliance on large sets of Tailwind utility classes."},"775":{"id":"/docs/getting-started/introduction-10","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Offers component variants through simple props such as `variant`, `color`, and `size`."},"776":{"id":"/docs/getting-started/introduction-11","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports full customization using the `className` prop and Tailwind utility classes."},"777":{"id":"/docs/getting-started/introduction-12","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Provides global and component-specific CSS variables for deeper configuration."},"778":{"id":"/docs/getting-started/introduction-13","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Includes complete TypeScript definitions for every component."},"779":{"id":"/docs/getting-started/introduction-14","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#why-hummingbird-react","content":"Supports tree shaking through per-component imports."},"780":{"id":"/docs/getting-started/introduction-15","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"HTML"},"781":{"id":"/docs/getting-started/introduction-16","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"CSS"},"782":{"id":"/docs/getting-started/introduction-17","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"JavaScript"},"783":{"id":"/docs/getting-started/introduction-18","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"React"},"784":{"id":"/docs/getting-started/introduction-19","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#pre-requisite-knowledge","content":"Tailwind CSS"},"785":{"id":"/docs/getting-started/introduction-20","page_id":"/docs/getting-started/introduction","tags":[],"type":"text","url":"/docs/getting-started/introduction#join-our-community","content":"If you have any questions about Hummingbird React, you can reach out to our community on GitHub Discussions, Discord or X (Twitter)."},"786":{"id":"/docs/layout/grid","page_id":"/docs/layout/grid","type":"page","content":"Grid","breadcrumbs":["Docs","Layout"],"tags":[],"url":"/docs/layout/grid"},"787":{"id":"/docs/layout/grid-0","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid","content":"The Grid is a twelve-column, flexbox-based layout system built from Container, Row, and Col components. It provides a familiar row and column structure for building responsive designs."},"788":{"id":"/docs/layout/grid-1","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#basic-example","content":"Basic example"},"789":{"id":"/docs/layout/grid-2","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#auto-layout-columns","content":"Auto-layout columns"},"790":{"id":"/docs/layout/grid-3","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#equal-width","content":"Equal-width"},"791":{"id":"/docs/layout/grid-4","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#variable-width-content","content":"Variable width content"},"792":{"id":"/docs/layout/grid-5","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#responsive-props","content":"Responsive props"},"793":{"id":"/docs/layout/grid-6","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#all-breakpoints","content":"All breakpoints"},"794":{"id":"/docs/layout/grid-7","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#mix-and-match","content":"Mix and match"},"795":{"id":"/docs/layout/grid-8","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row-columns","content":"Row columns"},"796":{"id":"/docs/layout/grid-9","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#nesting","content":"Nesting"},"797":{"id":"/docs/layout/grid-10","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#columns","content":"Columns"},"798":{"id":"/docs/layout/grid-11","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#vertical-alignment","content":"Vertical alignment"},"799":{"id":"/docs/layout/grid-12","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#horizontal-alignment","content":"Horizontal alignment"},"800":{"id":"/docs/layout/grid-13","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#order-classes","content":"Order classes"},"801":{"id":"/docs/layout/grid-14","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#offsetting-columns","content":"Offsetting columns"},"802":{"id":"/docs/layout/grid-15","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#gutters","content":"Gutters"},"803":{"id":"/docs/layout/grid-16","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#horizontal-gutters","content":"Horizontal gutters"},"804":{"id":"/docs/layout/grid-17","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#vertical-gutters","content":"Vertical gutters"},"805":{"id":"/docs/layout/grid-18","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#horizontal--vertical-gutters","content":"Horizontal & vertical gutters"},"806":{"id":"/docs/layout/grid-19","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row-columns-gutters","content":"Row columns gutters"},"807":{"id":"/docs/layout/grid-20","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#no-gutters","content":"No gutters"},"808":{"id":"/docs/layout/grid-21","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#api-reference","content":"API Reference"},"809":{"id":"/docs/layout/grid-22","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#container","content":"Container"},"810":{"id":"/docs/layout/grid-23","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#row","content":"Row"},"811":{"id":"/docs/layout/grid-24","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#col","content":"Col"},"812":{"id":"/docs/layout/grid-25","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#css-variables","content":"CSS variables"},"813":{"id":"/docs/layout/grid-26","page_id":"/docs/layout/grid","type":"heading","tags":[],"url":"/docs/layout/grid#styling","content":"Styling"},"814":{"id":"/docs/layout/grid-27","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#basic-example","content":"The Grid uses the `Container`, `Row`, and `Col` components to create responsive layouts. It is built with flexbox and adapts to different screen sizes."},"815":{"id":"/docs/layout/grid-28","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#auto-layout-columns","content":"Breakpoint props allow easy sizing of columns without setting an explicit numbered span."},"816":{"id":"/docs/layout/grid-29","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#equal-width","content":"A `Col` without any props creates equal-width columns for every screen size."},"817":{"id":"/docs/layout/grid-30","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#variable-width-content","content":"Setting a breakpoint prop to `\"auto\"` sizes the column based on the natural width of its content."},"818":{"id":"/docs/layout/grid-31","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#responsive-props","content":"The `xs`, `sm`, `md`, `lg`, `xl`, and `xxl` props specify different column sizes for different screen sizes. Breakpoints are defined using minimum widths, meaning each one applies from that width upward. For example, `md={4}` applies to medium devices (tablets) and above, and renders the `md:col-4` class."},"819":{"id":"/docs/layout/grid-32","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#all-breakpoints","content":"For grids that are the same across all breakpoints, plain `Col` and the `xs` prop are enough."},"820":{"id":"/docs/layout/grid-33","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#mix-and-match","content":"Different breakpoint props can be combined on the same column for different screen sizes."},"821":{"id":"/docs/layout/grid-34","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns","content":"Instead of sizing each column, the `Row` breakpoint props set the number of columns per row. The grid automatically lays out the columns evenly, and `\"auto\"` sizes them based on their content."},"822":{"id":"/docs/layout/grid-35","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#nesting","content":"Nesting works by placing a new `Row` and set of `Col` components inside an existing `Col`. This gives more control over the layout of the content."},"823":{"id":"/docs/layout/grid-36","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#columns","content":"Columns can be modified with options for alignment, ordering, and offsetting using the flexbox grid system."},"824":{"id":"/docs/layout/grid-37","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `items-start`, `items-center`, and `items-end` classes on `Row` control vertical alignment of all columns."},"825":{"id":"/docs/layout/grid-38","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-alignment","content":"The `self-start`, `self-center`, and `self-end` classes control vertical alignment of individual columns."},"826":{"id":"/docs/layout/grid-39","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-alignment","content":"The `justify-*` classes on `Row` control horizontal alignment."},"827":{"id":"/docs/layout/grid-40","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#order-classes","content":"The `order-{number}` classes change the visual order of columns."},"828":{"id":"/docs/layout/grid-41","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#offsetting-columns","content":"The object form of a breakpoint prop moves columns to the right. For example, `md={{ span: 4, offset: 4 }}` renders the `md:col-4 md:offset-4` classes, moving the column over four columns on medium screens and larger."},"829":{"id":"/docs/layout/grid-42","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#gutters","content":"Gutters are the spacing between columns, used to create consistent spacing and alignment in the grid system. Hummingbird supports gutter utilities up to `g-24` (6rem), applied to `Row` through the `className` prop."},"830":{"id":"/docs/layout/grid-43","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal-gutters","content":"The `gx-{size}` classes set horizontal gutters between columns."},"831":{"id":"/docs/layout/grid-44","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#vertical-gutters","content":"The `gy-{size}` classes set vertical gutters between rows."},"832":{"id":"/docs/layout/grid-45","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#horizontal--vertical-gutters","content":"The `g-{size}` classes set both horizontal and vertical gutters."},"833":{"id":"/docs/layout/grid-46","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#row-columns-gutters","content":"Gutter classes can be combined with the `Row` breakpoint props to create gutters between rows and columns."},"834":{"id":"/docs/layout/grid-47","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#no-gutters","content":"The `g-0` class removes all gutters between rows and columns."},"835":{"id":"/docs/layout/grid-48","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#api-reference","content":"The grid components are available from `@hummingbirdui/react` or the `@hummingbirdui/react/layout/grid` subpath. All three render a `<div>` and accept standard div attributes."},"836":{"id":"/docs/layout/grid-49","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#css-variables","content":"The Grid uses CSS variables for easy customization. Override these variables in the CSS to change the grid's behavior."},"837":{"id":"/docs/layout/grid-50","page_id":"/docs/layout/grid","tags":[],"type":"text","url":"/docs/layout/grid#styling","content":"Hummingbird React grid components are styled entirely through Hummingbird's grid classes and CSS variables. See the Hummingbird Grid documentation for the full class reference."}},"count":837},"sorting":{"language":"english","sortableProperties":["content","page_id","type","url"],"sortablePropertiesWithTypes":{"content":"string","page_id":"string","type":"string","url":"string"},"sorts":{"content":{"docs":{"1":86,"2":84,"3":238,"4":442,"5":278,"6":109,"7":589,"8":465,"9":761,"10":93,"11":318,"12":365,"13":526,"14":793,"15":95,"16":292,"17":239,"18":783,"19":196,"20":830,"21":110,"22":96,"23":97,"24":590,"25":725,"26":714,"27":656,"28":6,"29":366,"30":527,"31":794,"32":141,"33":107,"34":240,"35":569,"36":585,"37":306,"38":339,"39":111,"40":142,"41":143,"42":591,"43":105,"44":694,"45":708,"46":8,"47":9,"48":7,"49":367,"50":528,"51":795,"52":146,"53":74,"54"