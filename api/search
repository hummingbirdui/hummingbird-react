":"/docs/customize/dark-mode-13","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"The dark palette overrides those same variables inside `@variant dark`."},"67":{"id":"/docs/customize/dark-mode-14","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#how-it-works","content":"Toggling a `.dark` class switches all values globally."},"68":{"id":"/docs/customize/dark-mode-15","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"All components rely on the same semantic tokens:"},"69":{"id":"/docs/customize/dark-mode-16","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--background-color-default`"},"70":{"id":"/docs/customize/dark-mode-17","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--text-color-default`"},"71":{"id":"/docs/customize/dark-mode-18","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--color-primary`"},"72":{"id":"/docs/customize/dark-mode-19","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#key-idea","content":"`--border-color-default`"},"73":{"id":"/docs/customize/dark-mode-20","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#result","content":"Switching themes requires no component changes — only variable values update. Every Hummingbird React component adapts automatically."},"74":{"id":"/docs/customize/dark-mode-21","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#customizing-dark-mode","content":"Override variables after importing Hummingbird:"},"75":{"id":"/docs/customize/dark-mode-22","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#1-custom-dark-mode-selector","content":"Enable class-based dark mode after importing Tailwind and Hummingbird styles:"},"76":{"id":"/docs/customize/dark-mode-23","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#2-set-the-initial-theme","content":"Render `ThemeModeScript` inside `<head>` to apply the saved theme before first paint — no flash of the wrong theme. Safe in React Server Components."},"77":{"id":"/docs/customize/dark-mode-24","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"`DarkThemeToggle` switches between light and dark mode, persists the choice, and keeps all tabs in sync."},"78":{"id":"/docs/customize/dark-mode-25","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"Pass your own icons to replace the default sun/moon:"},"79":{"id":"/docs/customize/dark-mode-26","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#3-add-a-theme-toggle","content":"It is built on Button, so all `Button` props work too."},"80":{"id":"/docs/customize/dark-mode-27","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#the-usethememode-hook","content":"For custom controls, use `useThemeMode`. It applies the `.dark` class, follows the OS preference in `\"system\"` mode, and stays in sync across components and browser tabs. `DarkThemeToggle` uses it internally."},"81":{"id":"/docs/customize/dark-mode-28","page_id":"/docs/customize/dark-mode","tags":[],"type":"text","url":"/docs/customize/dark-mode#dark-mode-variable-overrides","content":"A list of theme variables that are overridden when dark mode is active."},"82":{"id":"/docs/customize/reboot","page_id":"/docs/customize/reboot","type":"page","content":"Reboot","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/reboot"},"83":{"id":"/docs/customize/reboot-0","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot","content":"Reboot is a file that includes a set of CSS with element-specific changes that gives Hummingbird a clean, consistent starting point for building websites."},"84":{"id":"/docs/customize/reboot-1","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#css-variables","content":"CSS variables"},"85":{"id":"/docs/customize/reboot-2","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#headings","content":"Headings"},"86":{"id":"/docs/customize/reboot-3","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#paragraph","content":"Paragraph"},"87":{"id":"/docs/customize/reboot-4","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#links","content":"Links"},"88":{"id":"/docs/customize/reboot-5","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#buttons","content":"Buttons"},"89":{"id":"/docs/customize/reboot-6","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#horizontal-rules","content":"Horizontal rules"},"90":{"id":"/docs/customize/reboot-7","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#lists","content":"Lists"},"91":{"id":"/docs/customize/reboot-8","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#description-lists","content":"Description lists"},"92":{"id":"/docs/customize/reboot-9","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#code","content":"Code"},"93":{"id":"/docs/customize/reboot-10","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#address","content":"Address"},"94":{"id":"/docs/customize/reboot-11","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#blockquote","content":"Blockquote"},"95":{"id":"/docs/customize/reboot-12","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#legend","content":"Legend"},"96":{"id":"/docs/customize/reboot-13","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#captions","content":"Captions"},"97":{"id":"/docs/customize/reboot-14","page_id":"/docs/customize/reboot","type":"heading","tags":[],"url":"/docs/customize/reboot#reboot-css-variables","content":"Reboot CSS variables"},"98":{"id":"/docs/customize/reboot-15","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"CSS variables provide a powerful way to customize and theme projects. It is a feature in modern CSS that allows defining reusable values directly in stylesheets. CSS variables make customization easy: change a value in one place (like `:root`) and it updates everywhere the variable is used. Variables can be set at different levels (global, component, etc.), making them flexible."},"99":{"id":"/docs/customize/reboot-16","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"A \"Reboot\" stylesheet (like Hummingbird's Reboot) resets browser styles and sets up a foundation for consistent design. Using CSS variables in Reboot makes it easy to customize base styles without editing the core CSS — just override the variables."},"100":{"id":"/docs/customize/reboot-17","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Tailwind CSS uses CSS variables for theming and customization. Hummingbird makes use of Tailwind's CSS variable feature to define colors, typography, spacing, and more. This allows projects to easily adapt the design system to specific needs. Learn more about Hummingbird's CSS variables in the Theming section."},"101":{"id":"/docs/customize/reboot-18","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#css-variables","content":"Reboot is included automatically when Hummingbird CSS is imported, so JSX elements rendered by React components get these base styles with no extra setup."},"102":{"id":"/docs/customize/reboot-19","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#headings","content":"All the headings (`h1` to `h6`) in Hummingbird are styled with CSS variables for font size, weight, line height, and margin."},"103":{"id":"/docs/customize/reboot-20","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#paragraph","content":"For all paragraph (`<p>`) elements, `margin-top` was removed, and `margin-bottom: 1rem` is set."},"104":{"id":"/docs/customize/reboot-21","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#links","content":"Links are styled with a default `color` and an `underline`. On hover, the link color changes to a darker shade."},"105":{"id":"/docs/customize/reboot-22","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#buttons","content":"By default, buttons (`<button>`) have a `cursor-pointer` style. When a button is disabled, the cursor changes to `cursor-default`."},"106":{"id":"/docs/customize/reboot-23","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#horizontal-rules","content":"Default `margin-top` and `margin-bottom` for horizontal rules (`<hr>`) is set to `1rem`."},"107":{"id":"/docs/customize/reboot-24","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#lists","content":"By default, unordered lists (`<ul>`) use disc bullets, and ordered lists (`<ol>`) use decimal numbers. Both types of lists have a left padding of `2rem` and a bottom margin of `1rem`. Nested lists have no bottom margin."},"108":{"id":"/docs/customize/reboot-25","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#description-lists","content":"Terms (`<dt>`) are styled with a bold font weight, while descriptions (`<dd>`) use a regular font weight. Default `margin-bottom` for `<dl>` is `1rem`."},"109":{"id":"/docs/customize/reboot-26","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#code","content":"By default, inline code elements (`<code>`) are styled with a specific text color and font size. When a `<code>` element is nested inside an `<a>` tag, it inherits the link's text color and font size."},"110":{"id":"/docs/customize/reboot-27","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#address","content":"The `<address>` element is styled with a bottom margin of `1rem`."},"111":{"id":"/docs/customize/reboot-28","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#blockquote","content":"By default, blockquotes (`<blockquote>`) have a bottom margin of `1rem`."},"112":{"id":"/docs/customize/reboot-29","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#legend","content":"The `<legend>` element is styled to be a block-level element with full width, no padding, and specific margin, font weight, and font size."},"113":{"id":"/docs/customize/reboot-30","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#captions","content":"By default, table captions (`<caption>`) are aligned to the left and positioned at the bottom of the table. They also have specific font weight and padding."},"114":{"id":"/docs/customize/reboot-31","page_id":"/docs/customize/reboot","tags":[],"type":"text","url":"/docs/customize/reboot#reboot-css-variables","content":"The following CSS variables are defined in Hummingbird for reboot styles. Override these variables in the CSS to customize the base styles of the project."},"115":{"id":"/docs/customize/theming","page_id":"/docs/customize/theming","type":"page","content":"Theming","breadcrumbs":["Docs","Customize"],"tags":[],"url":"/docs/customize/theming"},"116":{"id":"/docs/customize/theming-0","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming","content":"Learn how to customize Hummingbird React with Tailwind CSS v4 theme variables, override tokens, and support multiple themes and dark mode."},"117":{"id":"/docs/customize/theming-1","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#overview","content":"Overview"},"118":{"id":"/docs/customize/theming-2","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#available-themes","content":"Available themes"},"119":{"id":"/docs/customize/theming-3","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-themes","content":"How to use themes"},"120":{"id":"/docs/customize/theming-4","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#customizing-theme","content":"Customizing theme"},"121":{"id":"/docs/customize/theming-5","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#spacing","content":"Spacing"},"122":{"id":"/docs/customize/theming-6","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#breakpoints","content":"Breakpoints"},"123":{"id":"/docs/customize/theming-7","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#list-of-theme-variables","content":"List of theme variables"},"124":{"id":"/docs/customize/theming-8","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"How to use multiple themes at once"},"125":{"id":"/docs/customize/theming-9","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#reboot","content":"Reboot"},"126":{"id":"/docs/customize/theming-10","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwinds-helper-functions","content":"Tailwind's helper functions"},"127":{"id":"/docs/customize/theming-11","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--spacing","content":"`--spacing()`"},"128":{"id":"/docs/customize/theming-12","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#--alpha","content":"`--alpha()`"},"129":{"id":"/docs/customize/theming-13","page_id":"/docs/customize/theming","type":"heading","tags":[],"url":"/docs/customize/theming#tailwind-theme-variable-namespaces","content":"Tailwind theme variable namespaces"},"130":{"id":"/docs/customize/theming-14","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Hummingbird React is styled by Hummingbird CSS, which is built on Tailwind CSS v4 and provides a comprehensive set of theme variables (design tokens) for colors, typography, shadows, and more. Because theming happens entirely in CSS, no React code changes are needed to restyle the components."},"131":{"id":"/docs/customize/theming-15","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Offers multiple prebuilt themes like luxury, retro, arctic etc. These themes are highly customizable, allowing individual tokens to be tweaked or entirely new color palettes to be created to match specific brand aesthetics."},"132":{"id":"/docs/customize/theming-16","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Use the theme variables (like `--color-primary` and `--shadow-md`) via standard Tailwind utilities (for example, `bg-primary`, `text-primary`, `shadow-md`)."},"133":{"id":"/docs/customize/theming-17","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Override any theme variables globally by redefining them in an `@theme { ... }` block after importing the CSS."},"134":{"id":"/docs/customize/theming-18","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#overview","content":"Reboot provides a base CSS reset with element-specific styles for consistent design across browsers."},"135":{"id":"/docs/customize/theming-19","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Here is a quick overview of the available prebuilt themes:"},"136":{"id":"/docs/customize/theming-20","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"The signature Hummingbird theme with balanced neutrals and vibrant blue\naccents."},"137":{"id":"/docs/customize/theming-21","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Rich maroon and golden tones crafted for a refined, premium appearance."},"138":{"id":"/docs/customize/theming-22","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm vintage-inspired colors that bring a classic and timeless feel."},"139":{"id":"/docs/customize/theming-23","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Cool blues and frosty tones inspired by modern winter landscapes."},"140":{"id":"/docs/customize/theming-24","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Fresh greens and earthy shades inspired by the natural world."},"141":{"id":"/docs/customize/theming-25","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep purples and vivid pinks designed for bold, high-contrast\ninterfaces."},"142":{"id":"/docs/customize/theming-26","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Warm oranges and amber tones that create an energetic, glowing\naesthetic."},"143":{"id":"/docs/customize/theming-27","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#available-themes","content":"Deep blues and indigos designed for calm, modern dark experiences."},"144":{"id":"/docs/customize/theming-28","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"By default, Hummingbird includes the `default` theme. To use a different prebuilt theme, simply import the corresponding CSS file in the main CSS file (e.g., `globals.css`). Each theme has built-in dark mode support, so dark mode will automatically work when the theme is imported."},"145":{"id":"/docs/customize/theming-29","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-themes","content":"Only one theme should be imported at a time, as importing multiple themes will cause the last one to override the others."},"146":{"id":"/docs/customize/theming-30","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#customizing-theme","content":"Redefine theme variables by declaring them in `@theme` after importing Hummingbird:"},"147":{"id":"/docs/customize/theming-31","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#spacing","content":"Customize spacing by overriding the default spacing variable or defining new ones as needed."},"148":{"id":"/docs/customize/theming-32","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#breakpoints","content":"Customize and add new responsive breakpoints by overriding `--breakpoint-*` variables:"},"149":{"id":"/docs/customize/theming-33","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#list-of-theme-variables","content":"Hummingbird provides a small, consistent set of semantic theme variables. These variables create utilities and can be overridden later to change the look and feel without changing any component code. See dark mode variable overrides here."},"150":{"id":"/docs/customize/theming-34","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Hummingbird uses a small set of theme variables. By overriding these variables within a new theme scope, multiple themes can be created."},"151":{"id":"/docs/customize/theming-35","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Create a custom variant for the new themes."},"152":{"id":"/docs/customize/theming-36","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#how-to-use-multiple-themes-at-once","content":"Define the theme variables within the new variant scope. To use an existing theme's colors, simply copy all the variables from the corresponding Hummingbird theme file and paste them into the new variant scope."},"153":{"id":"/docs/customize/theming-37","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs/customize/theming#reboot","content":"Reboot is a foundational stylesheet that resets browser defaults and applies basic element styles. It provides a clean, consistent starting point for building interfaces and ensures visual consistency across browsers."},"154":{"id":"/docs/customize/theming-38","page_id":"/docs/customize/theming","tags":[],"type":"text","url":"/docs