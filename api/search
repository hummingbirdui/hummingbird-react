ize/colors#overview","content":"`bg-subtle`"},"17":{"id":"/docs/customize/colors-15","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"`border-subtle` etc."},"18":{"id":"/docs/customize/colors-16","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"This approach prevents dependence on specific palette values (`blue-500`, `green-600`, etc.). Instead, components reference semantic roles (`primary`, `secondary`, `warning`), making the UI easier to maintain, brand, and theme."},"19":{"id":"/docs/customize/colors-17","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#overview","content":"Behind the scenes, each semantic color class points to a CSS variable. Updating or overriding that variable updates the color everywhere it is used — including inside every Hummingbird React component."},"20":{"id":"/docs/customize/colors-18","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Here is the list of semantic colors that will be generated as Tailwind utilities and also available as CSS variables."},"21":{"id":"/docs/customize/colors-19","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Background colors"},"22":{"id":"/docs/customize/colors-20","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Text colors"},"23":{"id":"/docs/customize/colors-21","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Border colors"},"24":{"id":"/docs/customize/colors-22","page_id":"/docs/customize/colors","tags":[],"type":"text","url":"/docs/customize/colors#list-of-semantic-colors","content":"Actions colors (generate all color-related utilities)"},"25"