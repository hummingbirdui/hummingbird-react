{
  "name": "@hummingbirdui/react",
  "version": "0.1.0",
  "description": "Hummingbird React component library using Radix UI primitives and Hummingbird CSS",
  "keywords": [
    "react",
    "components",
    "ui",
    "hummingbird",
    "radix-ui",
    "accessible",
    "headless"
  ],
  "homepage": "https://hbui.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/hummingbirdui/hummingbird-react.git"
  },
  "license": "MIT",
  "author": "Hummingbird",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@hummingbirdui/hummingbird": ">=1.0",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.10.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "5.9.2",
    "vitest": "^1.1.0"
  }
}
