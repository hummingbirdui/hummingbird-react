{
  "name": "hummingbird-react",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@hummingbirdui/hummingbird": "^1.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1"
  }
}
